# Copy to .env and fill in values. Never commit .env.

# Azure Functions base URL (no trailing slash)
# Local:  http://localhost:7071/api
# Deploy: https://YOUR-APP.azurewebsites.net/api
VITE_API_BASE=http://localhost:7071/api

# Set to true to use mock data even when VITE_API_BASE is set
VITE_USE_MOCK=false
